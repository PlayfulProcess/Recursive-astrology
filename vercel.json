{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    { "src": "viewer/**", "use": "@vercel/static" },
    { "src": "api/calculate_chart.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/calculate-chart", "dest": "/api/calculate_chart" },
    { "src": "/", "dest": "/viewer/astrology-viewer.html" },
    { "handle": "filesystem" }
  ]
}
